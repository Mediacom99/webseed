GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Path to Claude Code CLI binary (default: auto-detect via $PATH)
# CLAUDE_CLI_PATH=/Users/you/.local/bin/claude

# Path to Vercel CLI binary (default: auto-detect via $PATH)
# VERCEL_CLI_PATH=/usr/local/bin/vercel

GMAIL_CREDENTIALS_FILE=credentials.json
# GMAIL_TOKEN_FILE=token.json
CONTACT_EMAIL=your_email@example.com
# SENDER_NAME=Your Name
# GMAIL_LABEL_NAME=webseed-queue

# Vercel project name (all sites deploy under this single project)
# VERCEL_PROJECT_NAME=webseed
